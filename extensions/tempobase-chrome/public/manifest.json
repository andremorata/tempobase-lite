{
  "manifest_version": 3,
  "name": "TempoBase",
  "version": "0.1.0",
  "description": "Start and stop your TempoBase timer without leaving the browser.",
  "permissions": ["storage", "alarms"],
  "host_permissions": ["https://tempobase.pmr.dev/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "TempoBase",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
